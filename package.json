{
  "name": "puraflora",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "PuraFlora — e-commerce de suplementos naturais, naturopatia e saúde integrativa",
  "scripts": {
    "predev": "node scripts/prepare-images.mjs",
    "prebuild": "node scripts/prepare-images.mjs",
    "images": "node scripts/prepare-images.mjs",
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build:client": "vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --outfile=dist-server/index.js --packages=external",
    "build": "npm run check && npm run build:client && npm run build:server",
    "start": "NODE_ENV=production node dist-server/index.js",
    "preview": "vite preview",
    "check": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx server/seed.ts",
    "mcp": "tsx server/smartenvios/mcp.ts",
    "mcp:asaas": "tsx server/asaas/mcp.ts",
    "mcp:mercadopago": "tsx server/mercadopago/mcp.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "express": "^5.2.1",
    "framer-motion": "^12.23.24",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.545.0",
    "multer": "^2.2.0",
    "nanoid": "^6.0.0",
    "pg": "^8.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^17.0.8",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.3.1",
    "wouter": "^3.3.5"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.19.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "zod": "^3.24.1"
  }
}
