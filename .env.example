# ── SmartEnvios ──────────────────────────────────────────────────────────────
# Token gerado no painel SmartEnvios (deixe vazio = modo MOCK para testar a UX).
SMARTENVIOS_TOKEN=
# sandbox | production
SMARTENVIOS_ENV=sandbox
# Force o modo mock mesmo com token (1 = sim)
SMARTENVIOS_MOCK=

# ── Remetente / origem (dados da loja) ──────────────────────────────────────
SENDER_NAME=PuraFlora
SENDER_DOCUMENT=            # CNPJ da loja (só dígitos)
SENDER_ZIPCODE=            # CEP de origem (só dígitos)
SENDER_STREET=
SENDER_NUMBER=
SENDER_NEIGHBORHOOD=
SENDER_COMPLEMENT=
SENDER_PHONE=
SENDER_EMAIL=

# ── Regras de frete da loja ─────────────────────────────────────────────────
FREE_SHIPPING_ABOVE=199        # frete grátis a partir deste subtotal (R$); 0 = off
SHIPPING_DISCOUNT_PERCENT=0    # desconto % no frete
FREE_SHIPPING_SERVICES=        # serviços sempre grátis (nomes separados por vírgula)

# Documento fiscal: nfe (exige NF-e) ou dc (Declaração de Conteúdo)
DOCUMENT_MODE=dc
LABEL_DOCUMENT_TYPE=label_integrated_danfe

# ── Backend próprio (admin, produtos, pedidos) ──────────────────────────────
DATABASE_URL=postgresql://usuario@localhost:5432/puraflora
JWT_SECRET=                    # string aleatória (ex: openssl rand -hex 32)
ADMIN_EMAIL=admin@puraflora.com.br
ADMIN_PASSWORD=                # troque antes de ir para produção
PORT=5180

# ── Asaas (gateway de pagamento) ────────────────────────────────────────────
# Vazio = modo MOCK (simula PIX/boleto/cartão sem conta). Para o modo real,
# cole a chave do SANDBOX (sandbox.asaas.com → Integrações; começa com $aact_hmlg_).
ASAAS_API_KEY=
ASAAS_ENV=sandbox              # sandbox | production
ASAAS_MOCK=                    # 1 força mock mesmo com chave
ASAAS_USER_AGENT=PuraFlora     # obrigatório pela Asaas
ASAAS_WEBHOOK_TOKEN=           # segredo validado no header asaas-access-token (gere um forte)
ASAAS_WEBHOOK_URL=             # URL pública do endpoint /api/webhooks/asaas (túnel/VPS)
ASAAS_AUTO_LABEL=0             # 1 = gera etiqueta SmartEnvios ao confirmar pagamento
ASAAS_RECONCILE_MINUTES=5      # poller de reconciliação (0 desliga)
ASAAS_MAX_INSTALLMENTS=12      # máximo de parcelas no cartão

# ── Chatwoot (chat funcional no site) ───────────────────────────────────────
# Vazias = chat desligado (o site usa o botão do WhatsApp). Preencha após subir
# o Chatwoot na VPS e criar uma caixa de entrada "Website" (ver docs/chatwoot.md).
# São lidas em tempo de BUILD (Vite) — defina antes de `npm run build`.
VITE_CHATWOOT_BASE_URL=        # ex.: https://chat.puraflora.com.br
VITE_CHATWOOT_TOKEN=           # websiteToken da caixa de entrada Website

# ── Ponte Chatwoot ↔ WhatsApp (responder o chat do site pelo WhatsApp) ──────
# Vazias = ponte desligada (o chat continua funcionando só no painel Chatwoot).
# Fluxo completo e detalhes em server/chatwoot-bridge.ts.
CHATWOOT_API_BASE_URL=         # ex.: https://chat.puraflora.com.br
CHATWOOT_ACCOUNT_ID=           # id numérico da conta no Chatwoot
CHATWOOT_INBOX_ID=             # id da caixa de entrada Website (filtra eventos)
CHATWOOT_API_ACCESS_TOKEN=     # Access Token de AGENTE (perfil → Access Token)
EVOLUTION_API_URL=             # ex.: http://localhost:8085 (mesma máquina)
EVOLUTION_API_KEY=             # AUTHENTICATION_API_KEY do Evolution API
EVOLUTION_INSTANCE=            # nome da instância conectada (ex.: puraflora-suporte)
WHATSAPP_SUPPORT_NUMBER=       # número do suporte (self-chat), só dígitos com DDI
BRIDGE_WEBHOOK_SECRET=         # ?secret= das URLs de webhook (gere: openssl rand -hex 16)
